# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_BUCKET=field-verifications

# OpenStreetMap Configuration
OSM_TILE_SERVER=https://tile.openstreetmap.org
OSM_USER_AGENT=BrokerGuardFieldVerify/0.1.0
OSM_CACHE_DIR=./cache/osm_tiles
OSM_CACHE_TTL=86400

# API Configuration
API_HOST=0.0.0.0
API_PORT=8002
API_TITLE=BrokerGuard Field Verify API
API_VERSION=0.1.0
API_DEBUG=false

# Security
SECRET_KEY=change-this-to-a-random-secret-key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001

# Hash Configuration
HASH_ALGORITHM=sha256

# PDF Configuration
PDF_FONT=Helvetica
PDF_LOGO_PATH=./assets/logo.png

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
